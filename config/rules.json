{
  "rules": [
    {
      "name": "Local-AtenaNumber",
      "enabled": true,
      "category": "LocalRule",
      "pattern": "宛名番号[:：]?\\s*[0-9A-Za-z\\-]+",
      "replacement": "[宛名番号]",
      "priority": 10,
      "ignoreCase": false,
      "description": "宛名番号のラベル付き表現"
    },
    {
      "name": "Local-HouseholdNumber",
      "enabled": true,
      "category": "LocalRule",
      "pattern": "世帯番号[:：]?\\s*[0-9A-Za-z\\-]+",
      "replacement": "[世帯番号]",
      "priority": 11,
      "ignoreCase": false,
      "description": "世帯番号のラベル付き表現"
    },
    {
      "name": "Local-ApplicationNumber",
      "enabled": true,
      "category": "LocalRule",
      "pattern": "申請番号[:：]?\\s*[0-9A-Za-z\\-]+",
      "replacement": "[申請番号]",
      "priority": 12,
      "ignoreCase": false,
      "description": "申請番号のラベル付き表現"
    },
    {
      "name": "Local-ReceiptNumber",
      "enabled": true,
      "category": "LocalRule",
      "pattern": "受付番号[:：]?\\s*[0-9A-Za-z\\-]+",
      "replacement": "[受付番号]",
      "priority": 13,
      "ignoreCase": false,
      "description": "受付番号のラベル付き表現"
    },
    {
      "name": "Local-InsuredNumber",
      "enabled": true,
      "category": "LocalRule",
      "pattern": "被保険者番号[:：]?\\s*[0-9A-Za-z\\-]+",
      "replacement": "[被保険者番号]",
      "priority": 14,
      "ignoreCase": false,
      "description": "被保険者番号のラベル付き表現"
    },
    {
      "name": "Local-BeneficiaryNumber",
      "enabled": true,
      "category": "LocalRule",
      "pattern": "受給者番号[:：]?\\s*[0-9A-Za-z\\-]+",
      "replacement": "[受給者番号]",
      "priority": 15,
      "ignoreCase": false,
      "description": "受給者番号のラベル付き表現"
    },
    {
      "name": "Local-ResidentCode",
      "enabled": true,
      "category": "LocalRule",
      "pattern": "住民コード[:：]?\\s*[0-9A-Za-z\\-]+",
      "replacement": "[住民コード]",
      "priority": 16,
      "ignoreCase": false,
      "description": "住民コードのラベル付き表現"
    },
    {
      "name": "Local-LotNumber-Conservative",
      "enabled": true,
      "category": "LocalRule",
      "pattern": "\\d{1,3}丁目\\d{1,4}番\\d{1,4}号|\\d{1,4}番地",
      "replacement": "[地番候補]",
      "priority": 17,
      "ignoreCase": false,
      "description": "過検出を抑えた地番候補"
    },
    {
      "name": "Phone-General",
      "enabled": true,
      "category": "Phone",
      "pattern": "(?:0\\d{1,4}-?\\d{1,4}-?\\d{3,4})",
      "replacement": "[電話番号]",
      "priority": 20,
      "ignoreCase": false,
      "description": "固定・携帯電話番号"
    },
    {
      "name": "Email-General",
      "enabled": true,
      "category": "Email",
      "pattern": "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}",
      "replacement": "[メール]",
      "priority": 30,
      "ignoreCase": true,
      "description": "一般的なメール形式"
    },
    {
      "name": "PostalCode-General",
      "enabled": true,
      "category": "PostalCode",
      "pattern": "\\b\\d{3}-?\\d{4}\\b",
      "replacement": "[郵便番号]",
      "priority": 40,
      "ignoreCase": false,
      "description": "郵便番号"
    },
    {
      "name": "Date-WesternAndJapaneseEra",
      "enabled": true,
      "category": "Date",
      "pattern": "(?:\\b\\d{4}[/-]\\d{1,2}[/-]\\d{1,2}\\b|(?:令和|平成|昭和)(?:元|\\d{1,2})年\\d{1,2}月\\d{1,2}日)",
      "replacement": "[日付]",
      "priority": 50,
      "ignoreCase": false,
      "description": "西暦・和暦の日付候補"
    },
    {
      "name": "Address-Conservative",
      "enabled": true,
      "category": "Address",
      "pattern": "(?:東京都|北海道|(?:京都|大阪)府|..県).{1,20}(?:市|区|町|村).{0,30}(?:\\d{1,4}-\\d{1,4}(?:-\\d{1,4})?|\\d{1,4}丁目\\d{1,4}番\\d{1,4}号)",
      "replacement": "[住所]",
      "priority": 60,
      "ignoreCase": false,
      "description": "都道府県+市区町村+番地の保守的な住所候補"
    },
    {
      "name": "Name-Labeled",
      "enabled": true,
      "category": "Name",
      "pattern": "(?:氏名|名前|申請者|対象者|保護者|児童氏名|納税義務者|住民氏名)[:：]\\s*[一-龥々ぁ-んァ-ヶ]{1,12}(?:[ 　][一-龥々ぁ-んァ-ヶ]{1,12})?",
      "replacement": "[氏名]",
      "priority": 70,
      "ignoreCase": false,
      "description": "ラベル付き氏名候補"
    }
  ]
}
