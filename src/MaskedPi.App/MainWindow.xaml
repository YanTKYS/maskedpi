<Window x:Class="MaskedPi.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MaskedPi - 生成AI入力前マスキング補助" Height="860" Width="1280" MinHeight="760" MinWidth="1024">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFF9E8" BorderBrush="#FFDFAF" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <TextBlock TextWrapping="Wrap" FontSize="14">
                <Run Text="このツールは補助ツールです。すべての個人情報を完全に検出するものではありません。"/>
                <LineBreak/>
                <Run Text="生成AIへ送信する前に必ず最終確認してください。自由記述文や文脈依存情報は残る場合があります。"/>
            </TextBlock>
        </Border>

        <TextBlock Grid.Row="1" Name="StatusTextBlock" Foreground="#444" Margin="0,0,0,8" />

        <TabControl Grid.Row="2">
            <TabItem Header="マスキング">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="入力テキスト" Grid.Column="0" Margin="0,0,8,0" Padding="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Bottom" Name="InputCountTextBlock" Margin="0,8,0,0" Foreground="#666" />
                                <TextBox Name="InputTextBox" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" TextChanged="InputTextBox_OnTextChanged" FontFamily="Yu Gothic UI" FontSize="14" />
                            </DockPanel>
                        </GroupBox>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0" Width="170">
                            <TextBlock Text="業務プロファイル" Margin="0,0,0,4" />
                            <ComboBox Name="ProfileComboBox" Margin="0,0,0,8" />
                            <Button Name="MaskButton" Content="マスキング実行" Width="160" Height="38" Margin="0,0,0,8" Click="MaskButton_OnClick" />
                            <Button Name="ReloadButton" Content="設定再読込" Width="160" Height="34" Margin="0,0,0,8" Click="ReloadButton_OnClick" />
                            <Button Name="CopyButton" Content="結果をコピー" Width="160" Height="34" Margin="0,0,0,8" Click="CopyButton_OnClick" />
                            <Button Name="ClearButton" Content="クリア" Width="160" Height="34" Click="ClearButton_OnClick" />
                        </StackPanel>

                        <GroupBox Header="マスキング後テキスト" Grid.Column="2" Margin="8,0,0,0" Padding="8">
                            <TextBox Name="OutputTextBox" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Yu Gothic UI" FontSize="14" />
                        </GroupBox>
                    </Grid>

                    <TextBlock Grid.Row="1" Name="SummaryHeaderTextBlock" FontWeight="Bold" Margin="0,0,0,8" />

                    <GroupBox Grid.Row="2" Header="検出結果サマリ" Padding="8">
                        <DataGrid Name="SummaryDataGrid" IsReadOnly="True" AutoGenerateColumns="False" HeadersVisibility="Column" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="種別" Binding="{Binding CategoryLabel}" Width="2*" />
                                <DataGridTextColumn Header="件数" Binding="{Binding Count}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="ルールテスター">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="260" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="テスト入力" Grid.Column="0" Margin="0,0,8,0" Padding="8">
                            <TextBox Name="TesterInputTextBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Yu Gothic UI" FontSize="14" />
                        </GroupBox>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0" Width="170">
                            <TextBlock Text="テスタープロファイル" Margin="0,0,0,4" />
                            <ComboBox Name="TesterProfileComboBox" Margin="0,0,0,8" />
                            <Button Name="TesterRunButton" Content="テスト実行" Width="160" Height="38" Margin="0,0,0,8" Click="TesterRunButton_OnClick" />
                            <Button Name="TesterReloadButton" Content="設定再読込" Width="160" Height="34" Margin="0,0,0,8" Click="ReloadButton_OnClick" />
                            <Button Name="TesterCopyOutputButton" Content="出力をコピー" Width="160" Height="34" Margin="0,0,0,8" Click="TesterCopyOutputButton_OnClick" />
                            <Button Name="TesterCopyDetailButton" Content="詳細結果をコピー" Width="160" Height="34" Click="TesterCopyDetailButton_OnClick" />
                        </StackPanel>

                        <GroupBox Header="テスト出力" Grid.Column="2" Margin="8,0,0,0" Padding="8">
                            <TextBox Name="TesterOutputTextBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Yu Gothic UI" FontSize="14" />
                        </GroupBox>
                    </Grid>

                    <TextBlock Grid.Row="1" Name="TesterSummaryTextBlock" FontWeight="Bold" Margin="0,0,0,8" Text="ヒット件数: 0"/>

                    <GroupBox Grid.Row="2" Header="ヒット詳細" Padding="8">
                        <DataGrid Name="TesterHitsDataGrid" IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="RuleName" Binding="{Binding RuleName}" Width="2*" />
                                <DataGridTextColumn Header="Category" Binding="{Binding CategoryLabel}" Width="*" />
                                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="*" />
                                <DataGridTextColumn Header="MatchedText" Binding="{Binding MatchedText}" Width="2*" />
                                <DataGridTextColumn Header="Replacement" Binding="{Binding Replacement}" Width="*" />
                                <DataGridTextColumn Header="StartIndex" Binding="{Binding StartIndex}" Width="*" />
                                <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="*" />
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
